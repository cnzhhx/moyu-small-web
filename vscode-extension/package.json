{
  "name": "moyu-island",
  "displayName": "摸鱼岛",
  "description": "上班摸鱼神器 - 热榜聚合、下班倒计时、每日一言",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "moyuIsland.showPanel",
        "title": "摸鱼岛：打开面板"
      },
      {
        "command": "moyuIsland.openWebsite",
        "title": "摸鱼岛：打开摸鱼网站"
      },
      {
        "command": "moyuIsland.refreshHotlist",
        "title": "摸鱼岛：刷新热榜",
        "icon": "$(refresh)"
      },
      {
        "command": "moyuIsland.openHotlistItem",
        "title": "打开热榜条目"
      },
      {
        "command": "moyuIsland.viewHoliday",
        "title": "摸鱼岛：查看今日假期"
      },
      {
        "command": "moyuIsland.openSettings",
        "title": "摸鱼岛：打开设置"
      },
      {
        "command": "moyuIsland.refreshQuote",
        "title": "刷新每日一言"
      },
      {
        "command": "moyuIsland.searchHotlist",
        "title": "搜索热榜",
        "icon": "$(search)"
      },
      {
        "command": "moyuIsland.clearSearch",
        "title": "清除搜索",
        "icon": "$(close)"
      },
      {
        "command": "moyuIsland.favoriteItem",
        "title": "收藏此条"
      },
      {
        "command": "moyuIsland.unfavoriteItem",
        "title": "取消收藏"
      },
      {
        "command": "moyuIsland.openFavorites",
        "title": "打开收藏夹"
      },
      {
        "command": "moyuIsland.clearFavorites",
        "title": "清空收藏"
      },
      {
        "command": "moyuIsland.clearHistory",
        "title": "清空历史"
      },
      {
        "command": "moyuIsland.startBreak",
        "title": "休息5分钟"
      },
      {
        "command": "moyuIsland.skipBreak",
        "title": "跳过休息"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "moyuIsland.refreshHotlist",
          "when": "view == moyuIsland.hotlistTree",
          "group": "navigation@1"
        },
        {
          "command": "moyuIsland.searchHotlist",
          "when": "view == moyuIsland.hotlistTree",
          "group": "navigation@2"
        },
        {
          "command": "moyuIsland.clearSearch",
          "when": "view == moyuIsland.hotlistTree && moyuIsland.hasSearchFilter",
          "group": "navigation@3"
        },
        {
          "command": "moyuIsland.clearFavorites",
          "when": "view == moyuIsland.favoritesTree",
          "group": "navigation@1"
        },
        {
          "command": "moyuIsland.clearHistory",
          "when": "view == moyuIsland.historyTree",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "moyuIsland.openHotlistItem",
          "when": "view == moyuIsland.hotlistTree && viewItem == hotlistItem",
          "group": "inline@1"
        },
        {
          "command": "moyuIsland.favoriteItem",
          "when": "view == moyuIsland.hotlistTree && viewItem == hotlistItem",
          "group": "1_action@1"
        },
        {
          "command": "moyuIsland.unfavoriteItem",
          "when": "view == moyuIsland.favoritesTree",
          "group": "1_action@1"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "moyu-island",
          "title": "摸鱼岛",
          "icon": "$(smiley)"
        }
      ]
    },
    "views": {
      "moyu-island": [
        {
          "type": "webview",
          "id": "moyuIsland.mainView",
          "name": "摸鱼岛",
          "icon": "$(smiley)"
        },
        {
          "id": "moyuIsland.hotlistTree",
          "name": "热榜",
          "icon": "$(flame)"
        },
        {
          "id": "moyuIsland.favoritesTree",
          "name": "收藏",
          "icon": "$(star-full)"
        },
        {
          "id": "moyuIsland.historyTree",
          "name": "历史",
          "icon": "$(history)"
        }
      ]
    },
    "configuration": {
      "title": "摸鱼岛",
      "properties": {
        "moyuIsland.offWorkTime": {
          "type": "string",
          "default": "18:00",
          "description": "下班时间（HH:mm格式）"
        },
        "moyuIsland.serverUrl": {
          "type": "string",
          "default": "http://localhost:3001",
          "description": "摸鱼岛后端服务地址"
        },
        "moyuIsland.enableHotlist": {
          "type": "boolean",
          "default": true,
          "description": "是否启用热榜功能"
        },
        "moyuIsland.enableCountdown": {
          "type": "boolean",
          "default": true,
          "description": "是否启用下班倒计时"
        },
        "moyuIsland.tips": {
          "type": "array",
          "default": [
            "摸鱼的最高境界：让老板以为你在加班，同事以为你在开会",
            "建议每工作25分钟，摸鱼5分钟，这叫番茄摸鱼法🍅",
            "打开一个终端窗口放在旁边，看起来就像在编译代码",
            "记得时不时皱一下眉头，显得你在思考很难的问题",
            "摸鱼时记得把屏幕亮度调低，省电又护眼"
          ],
          "description": "自定义摸鱼小贴士列表",
          "items": {
            "type": "string"
          }
        },
        "moyuIsland.reminderInterval": {
          "type": "number",
          "default": 60,
          "minimum": 10,
          "maximum": 240,
          "description": "休息提醒间隔（分钟）"
        },
        "moyuIsland.enableReminder": {
          "type": "boolean",
          "default": true,
          "description": "是否启用休息提醒"
        },
        "moyuIsland.breakDuration": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 30,
          "description": "休息时长（分钟）"
        }
      }
    }
  }
}
